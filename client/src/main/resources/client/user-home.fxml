<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0"
            prefWidth="1000.0"
            stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.controller.UserDashboardController">

    <styleClass>
        <String fx:value="dashboard-root" />
        <String fx:value="user-dashboard-root" />
    </styleClass>

    <children>
        <HBox spacing="12.0"
              styleClass="app-shell"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">

            <children>
                <ScrollPane fitToWidth="true"
                            fitToHeight="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            pannable="true"
                            prefWidth="205.0"
                            minWidth="205.0"
                            maxWidth="205.0"
                            styleClass="sidebar-scroll">

                    <content>
                        <VBox prefWidth="205.0" spacing="15.0" styleClass="sidebar-shell">
                            <children>
                                <VBox spacing="11.0" styleClass="profile-card">
                                    <children>
                                        <StackPane maxWidth="Infinity" styleClass="profile-top-row">
                                            <children>
                                                <StackPane styleClass="avatar-circle" StackPane.alignment="CENTER">
                                                    <children>
                                                        <Label fx:id="avatarInitialsLabel" styleClass="avatar-text" text="AU" />
                                                    </children>
                                                </StackPane>

                                                <StackPane styleClass="notification-bell-wrap" StackPane.alignment="TOP_RIGHT">
                                                    <children>
                                                        <Button fx:id="notificationBellButton" mnemonicParsing="false" onAction="#handleNotificationBell" styleClass="notification-bell-btn" text="🔔" />
                                                        <Label fx:id="notificationBadgeLabel" styleClass="notification-badge" text="0" StackPane.alignment="TOP_RIGHT" />
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </StackPane>

                                        <Label fx:id="usernameLabel" styleClass="sidebar-name" text="Auction User" />
                                        <Label fx:id="emailLabel" styleClass="sidebar-email" text="user@auction.local" />
                                        <Label fx:id="roleLabel" styleClass="role-pill" text="BIDDER / SELLER" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="menu-title" text="NAVIGATION" />
                                        <Button fx:id="auctionsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Auctions" />
                                        <Button fx:id="myBidsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="My Bids" />
                                        <Button fx:id="autoBidsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Auto Bids" />
                                        <Button fx:id="myItemsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="My Items" />
                                        <Button fx:id="winnersBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Transactions" />
                                    </children>
                                </VBox>

                                <Region VBox.vgrow="ALWAYS" />

                                <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="logout-btn" text="Logout" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <ScrollPane fitToWidth="true"
                            fitToHeight="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            pannable="true"
                            styleClass="content-scroll"
                            HBox.hgrow="ALWAYS">

                    <content>
                        <VBox spacing="13.0" styleClass="content-shell">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="headerTitleLabel" styleClass="top-title" text="Dashboard" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="12.0" styleClass="surface-card" VBox.vgrow="ALWAYS">
                                    <children>
                                        <FlowPane fx:id="userActionBar" hgap="7.0" vgap="7.0" />
                                        <VBox fx:id="workspaceBox" spacing="12.0" styleClass="workspace-body" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>
                            </children>

                            <padding>
                                <Insets bottom="1.0" left="1.0" right="1.0" top="1.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </HBox>

        <Button fx:id="depositFloatingButton"
                managed="false"
                mnemonicParsing="false"
                onAction="#handleOpenDepositDialog"
                styleClass="floating-create-btn"
                text="Deposit"
                visible="false"
                AnchorPane.bottomAnchor="24.0"
                AnchorPane.rightAnchor="28.0" />

        <Button fx:id="createListingFloatingButton"
                managed="false"
                mnemonicParsing="false"
                onAction="#handleOpenCreateListing"
                styleClass="floating-create-btn"
                text="Create Listing"
                visible="false"
                AnchorPane.bottomAnchor="24.0"
                AnchorPane.rightAnchor="28.0" />
    </children>
</AnchorPane>
