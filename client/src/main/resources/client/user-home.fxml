<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0"
            prefWidth="1000.0"
            styleClass="dashboard-root"
            stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.controller.UserDashboardController">

    <children>
        <HBox spacing="12.0"
              styleClass="app-shell"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">

            <children>
                <ScrollPane fitToWidth="true"
                            fitToHeight="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            pannable="true"
                            prefWidth="205.0"
                            minWidth="205.0"
                            maxWidth="205.0"
                            styleClass="sidebar-scroll">

                    <content>
                        <VBox prefWidth="205.0" spacing="15.0" styleClass="sidebar-shell">
                            <children>
                                <VBox spacing="11.0" styleClass="profile-card">
                                    <children>
                                        <StackPane styleClass="avatar-circle">
                                            <children>
                                                <Label fx:id="avatarInitialsLabel" styleClass="avatar-text" text="AU" />
                                            </children>
                                        </StackPane>

                                        <Label fx:id="usernameLabel" styleClass="sidebar-name" text="Auction User" />
                                        <Label fx:id="emailLabel" styleClass="sidebar-email" text="user@auction.local" />
                                        <Label fx:id="roleLabel" styleClass="role-pill" text="BIDDER / SELLER" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="menu-title" text="NAVIGATION" />
                                        <Button fx:id="dashboardBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Dashboard" />
                                        <Button fx:id="auctionsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Auctions" />
                                        <Button fx:id="myBidsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="My Bids" />
                                        <Button fx:id="autoBidsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Auto Bids" />
                                        <Button fx:id="myItemsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="My Items" />
                                        <Button fx:id="winnersBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Transactions" />
                                        <Button fx:id="settingsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Settings" />
                                    </children>
                                </VBox>

                                <Region VBox.vgrow="ALWAYS" />

                                <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="logout-btn" text="Logout" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <ScrollPane fitToWidth="true"
                            fitToHeight="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            pannable="true"
                            styleClass="content-scroll"
                            HBox.hgrow="ALWAYS">

                    <content>
                        <VBox spacing="13.0" styleClass="content-shell">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="headerTitleLabel" styleClass="top-title" text="Dashboard" />
                                            </children>
                                        </VBox>

                                        <TextField fx:id="searchField" promptText="Search..." styleClass="search-field" />
                                    </children>
                                </HBox>

                                <FlowPane hgap="8.0" vgap="8.0" styleClass="stat-grid">
                                    <children>
                                        <VBox spacing="5.0" prefWidth="156.0" styleClass="stat-card">
                                            <children>
                                                <Label fx:id="statValue1" styleClass="stat-value" text="12" />
                                                <Label fx:id="statLabel1" styleClass="stat-label" text="Active Bids" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" prefWidth="156.0" styleClass="stat-card">
                                            <children>
                                                <Label fx:id="statValue2" styleClass="stat-value" text="04" />
                                                <Label fx:id="statLabel2" styleClass="stat-label" text="Winning Now" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" prefWidth="156.0" styleClass="stat-card">
                                            <children>
                                                <Label fx:id="statValue3" styleClass="stat-value" text="03" />
                                                <Label fx:id="statLabel3" styleClass="stat-label" text="Outbid" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" prefWidth="156.0" styleClass="stat-card">
                                            <children>
                                                <Label fx:id="statValue4" styleClass="stat-value" text="08" />
                                                <Label fx:id="statLabel4" styleClass="stat-label" text="Ending Soon" />
                                            </children>
                                        </VBox>
                                    </children>
                                </FlowPane>

                                <VBox spacing="13.0" styleClass="surface-card" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="surfaceTitleLabel" styleClass="surface-title" text="User Auction Workspace" />
                                        <FlowPane fx:id="userActionBar" hgap="7.0" vgap="7.0" />

                                        <VBox spacing="9.0" styleClass="table-card" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="workspaceTitleLabel" styleClass="table-title" text="Action Needed" />
                                                <VBox fx:id="workspaceBox" spacing="9.0" VBox.vgrow="ALWAYS" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0" styleClass="activity-card">
                                            <children>
                                                <Label styleClass="placeholder-title" text="Recent Activity" />
                                                <Label fx:id="activityLine1" styleClass="activity-line" text="You were outbid on Vintage Camera." wrapText="true" />
                                                <Label fx:id="activityLine2" styleClass="activity-line" text="MacBook Pro M3 ends in 42 minutes." wrapText="true" />
                                                <Label fx:id="activityLine3" styleClass="activity-line" text="Mechanical Keyboard sale is ready to ship." wrapText="true" />
                                                <Label fx:id="activityLine4" styleClass="activity-line" text="Auto bid reached 80% of max limit." wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>

                            <padding>
                                <Insets bottom="1.0" left="1.0" right="1.0" top="1.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </HBox>

        <Button fx:id="createListingFloatingButton"
                managed="false"
                mnemonicParsing="false"
                onAction="#handleOpenCreateListing"
                styleClass="floating-create-btn"
                text="Create Listing"
                visible="false"
                AnchorPane.bottomAnchor="24.0"
                AnchorPane.rightAnchor="28.0" />
    </children>
</AnchorPane>
