<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1150.0" styleClass="root-bg" stylesheets="@auth.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.AuthController">

    <children>
        <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <AnchorPane fx:id="mainCard" maxHeight="540.0" maxWidth="860.0" minHeight="540.0" minWidth="860.0" prefHeight="540.0" prefWidth="860.0" styleClass="main-card">

                    <children>
                        <HBox fx:id="formsLayer" maxHeight="540.0" maxWidth="860.0" minHeight="540.0" minWidth="860.0" prefHeight="540.0" prefWidth="860.0">
                            <children>

                                <!-- SIGN IN -->
                                <VBox fx:id="signInFormPane" alignment="CENTER" maxHeight="540.0" maxWidth="430.0" minHeight="540.0" minWidth="430.0" prefHeight="540.0" prefWidth="430.0" spacing="16.0" styleClass="form-pane">
                                    <padding>
                                        <Insets left="58.0" right="58.0" />
                                    </padding>

                                    <children>
                                        <Label styleClass="title" text="Sign In" />
                                        <Label styleClass="sub-title" text="Use your account to continue" />

                                        <TextField fx:id="signInIdentityField" prefHeight="46.0" prefWidth="300.0" promptText="Username or Email" styleClass="input" />

                                        <PasswordField fx:id="signInPasswordField" prefHeight="46.0" prefWidth="300.0" promptText="Password" styleClass="input" />

                                        <Button fx:id="signInBtn" mnemonicParsing="false" onAction="#handleSignIn" prefHeight="44.0" prefWidth="170.0" styleClass="round-btn" text="SIGN IN" />

                                        <Label fx:id="signInMessageLabel" prefWidth="300.0" styleClass="message-label" text="" wrapText="true" />
                                    </children>
                                </VBox>

                                <!-- SIGN UP -->
                                <VBox fx:id="signUpFormPane" alignment="TOP_CENTER" maxHeight="540.0" maxWidth="430.0" minHeight="540.0" minWidth="430.0" prefHeight="540.0" prefWidth="430.0" spacing="16.0" styleClass="form-pane">
                                    <padding>
                                        <Insets bottom="50.0" left="58.0" right="58.0" top="62.0" />
                                    </padding>

                                    <children>
                                        <Label styleClass="title" text="Create Account" />
                                        <Label styleClass="sub-title" text="Register to start your journey" />

                                        <TextField fx:id="signUpUsernameField" prefHeight="46.0" prefWidth="300.0" promptText="Username" styleClass="input" />

                                        <TextField fx:id="signUpEmailField" prefHeight="46.0" prefWidth="300.0" promptText="Email" styleClass="input" />

                                        <PasswordField fx:id="signUpPasswordField" prefHeight="46.0" prefWidth="300.0" promptText="Password" styleClass="input" />

                                        <PasswordField fx:id="signUpConfirmPasswordField" prefHeight="46.0" prefWidth="300.0" promptText="Confirm Password" styleClass="input" />

                                        <Button fx:id="signUpBtn" mnemonicParsing="false" onAction="#handleSignUp" prefHeight="44.0" prefWidth="170.0" styleClass="round-btn" text="SIGN UP" />

                                        <Label fx:id="signUpMessageLabel" prefWidth="300.0" styleClass="message-label" text="" wrapText="true" />
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <!-- OVERLAY -->
                        <AnchorPane fx:id="overlayPane" layoutX="0.0" maxHeight="540.0" maxWidth="430.0" minHeight="540.0" minWidth="430.0" prefHeight="540.0" prefWidth="430.0" styleClass="overlay-pane">
                            <children>
                                <StackPane fx:id="overlayViewport" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <children>
                                        <ImageView fx:id="overlayImageView" fitHeight="540.0" fitWidth="860.0" opacity="0.96" pickOnBounds="true" preserveRatio="false" smooth="true" />

                                        <VBox fx:id="overlayWelcomePane" alignment="TOP_LEFT" fillWidth="true" spacing="0.0">
                                            <children>
                                                <VBox alignment="TOP_LEFT" fillWidth="true" maxWidth="320.0" prefWidth="320.0" spacing="18.0">
                                                    <children>
                                                        <Label alignment="CENTER_LEFT" maxWidth="320.0" prefWidth="320.0" styleClass="overlay-title-left" text="Professional bidding, redefined." textAlignment="LEFT" wrapText="true">
                                                            <VBox.margin>
                                                                <Insets left="10.0" top="50.0" />
                                                            </VBox.margin>
                                                        </Label>

                                                        <Label alignment="CENTER_LEFT" maxWidth="320.0" prefWidth="320.0" styleClass="overlay-desc-left" text="Access opportunities, place bids seamlessly, and manage the process with confidence." textAlignment="LEFT" wrapText="true">
                                                            <VBox.margin>
                                                                <Insets left="10.0" />
                                                            </VBox.margin>
                                                        </Label>
                                                    </children>
                                                </VBox>

                                                <Region VBox.vgrow="ALWAYS" />

                                                <VBox alignment="CENTER" fillWidth="false" maxWidth="400.0" prefWidth="320.0" spacing="8.0">
                                                    <children>
                                                        <Label alignment="CENTER" maxWidth="400.0" prefHeight="43.0" prefWidth="376.0" styleClass="overlay-desc-center" text="New to our platform? Create an account to get started." textAlignment="CENTER" wrapText="true" />

                                                        <Button fx:id="switchToSignUpBtn" mnemonicParsing="false" onAction="#showSignUp" prefHeight="42.0" prefWidth="170.0" styleClass="ghost-btn" text="SIGN UP" />
                                                    </children>
                                                </VBox>
                                            </children>

                                            <padding>
                                                <Insets bottom="55.0" left="40.0" right="40.0" top="55.0" />
                                            </padding>
                                        </VBox>

                                        <VBox fx:id="overlayHelloPane" alignment="TOP_LEFT" fillWidth="true" managed="false" opacity="0.0" spacing="0.0" visible="false">
                                            <children>
                                                <VBox alignment="TOP_LEFT" fillWidth="true" maxWidth="320.0" prefWidth="320.0" spacing="18.0">
                                                    <children>
                                                        <Label alignment="CENTER_LEFT" maxWidth="320.0" prefWidth="320.0" styleClass="overlay-title-left" text="Elevate your bidding experience." textAlignment="LEFT" wrapText="true">
                                                            <VBox.margin>
                                                                <Insets left="10.0" top="50.0" />
                                                            </VBox.margin>
                                                        </Label>

                                                        <Label alignment="CENTER_LEFT" maxWidth="320.0" prefWidth="320.0" styleClass="overlay-desc-left" text="Join a trusted platform designed to simplify and strengthen your bidding experience." textAlignment="LEFT" wrapText="true">
                                                            <VBox.margin>
                                                                <Insets left="10.0" />
                                                            </VBox.margin>
                                                        </Label>
                                                    </children>
                                                </VBox>

                                                <Region VBox.vgrow="ALWAYS" />

                                                <VBox alignment="CENTER" fillWidth="false" maxWidth="320.0" prefWidth="320.0" spacing="18.0">
                                                    <children>
                                                        <Label alignment="CENTER" maxWidth="320.0" prefWidth="320.0" styleClass="overlay-desc-center" text="Already registered? Sign in to continue." textAlignment="CENTER" wrapText="true" />

                                                        <Button fx:id="switchToSignInBtn" mnemonicParsing="false" onAction="#showSignIn" prefHeight="42.0" prefWidth="170.0" styleClass="ghost-btn" text="SIGN IN" />
                                                    </children>
                                                </VBox>
                                            </children>

                                            <padding>
                                                <Insets bottom="55.0" left="40.0" right="40.0" top="55.0" />
                                            </padding>
                                        </VBox>
                                    </children>
                                </StackPane>
                            </children>
                        </AnchorPane>

                    </children>
                </AnchorPane>
            </children>
        </StackPane>
    </children>
</AnchorPane>