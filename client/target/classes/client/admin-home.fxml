<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0"
            prefWidth="1000.0"
            styleClass="dashboard-root"
            stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.controller.AdminDashboardController">

    <children>
        <HBox spacing="12.0"
              styleClass="app-shell"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">

            <children>
                <ScrollPane fitToWidth="true"
                            fitToHeight="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            pannable="true"
                            prefWidth="205.0"
                            minWidth="205.0"
                            maxWidth="205.0"
                            styleClass="sidebar-scroll">

                    <content>
                        <VBox prefWidth="205.0" spacing="15.0" styleClass="sidebar-shell">
                            <children>
                                <VBox spacing="11.0" styleClass="profile-card">
                                    <children>
                                        <StackPane styleClass="avatar-circle">
                                            <children>
                                                <Label fx:id="avatarInitialsLabel" styleClass="avatar-text" text="AD" />
                                            </children>
                                        </StackPane>

                                        <Label fx:id="usernameLabel" styleClass="sidebar-name" text="Admin User" />
                                        <Label fx:id="emailLabel" styleClass="sidebar-email" text="admin@auction.local" />
                                        <Label fx:id="roleLabel" styleClass="role-pill" text="SYSTEM ADMIN" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="menu-title" text="CONTROL PANEL" />
                                        <Button fx:id="dashboardBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Dashboard" />
                                        <Button fx:id="usersBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Users" />
                                        <Button fx:id="auctionsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Auctions" />
                                        <Button fx:id="itemsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Items" />
                                        <Button fx:id="reportsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Reports" />
                                        <Button fx:id="settingsBtn" mnemonicParsing="false" onAction="#handleSidebarNavigation" styleClass="nav-btn" text="Settings" />
                                    </children>
                                </VBox>

                                <Region VBox.vgrow="ALWAYS" />

                                <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="logout-btn" text="Logout" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <ScrollPane fitToWidth="true"
                            fitToHeight="true"
                            hbarPolicy="NEVER"
                            vbarPolicy="AS_NEEDED"
                            pannable="true"
                            styleClass="content-scroll"
                            HBox.hgrow="ALWAYS">

                    <content>
                        <VBox spacing="13.0" styleClass="content-shell">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="headerTitleLabel" styleClass="top-title" text="Admin Dashboard" />
                                                <Label fx:id="headerSubtitleLabel" styleClass="top-subtitle" text="Monitor live auctions, users, items, reports, and system settings." wrapText="true" />
                                            </children>
                                        </VBox>

                                        <TextField fx:id="searchField" promptText="Search..." styleClass="search-field" />
                                        <Button fx:id="primaryActionButton" mnemonicParsing="false" styleClass="action-btn" text="Refresh" />
                                    </children>
                                </HBox>

                                <HBox spacing="8.0">
                                    <children>
                                        <VBox spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="statValue1" styleClass="stat-value" text="248" />
                                                <Label fx:id="statLabel1" styleClass="stat-label" text="Users" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="statValue2" styleClass="stat-value" text="31" />
                                                <Label fx:id="statLabel2" styleClass="stat-label" text="Running Auctions" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="statValue3" styleClass="stat-value" text="142" />
                                                <Label fx:id="statLabel3" styleClass="stat-label" text="Listed Items" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="statValue4" styleClass="stat-value" text="912" />
                                                <Label fx:id="statLabel4" styleClass="stat-label" text="Total Bids" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="13.0" styleClass="surface-card" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="surfaceTitleLabel" styleClass="surface-title" text="Control Center" />
                                        <Label fx:id="surfaceDescriptionLabel" styleClass="surface-desc" text="Practical admin workspace for auction health, moderation queues, and operational data." wrapText="true" />

                                        <FlowPane fx:id="adminActionBar" hgap="7.0" vgap="7.0" />

                                        <VBox spacing="9.0" styleClass="table-card" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="tableTitleLabel" styleClass="table-title" text="Operational Queue" />
                                                <VBox fx:id="dataRowsBox" spacing="7.0" VBox.vgrow="ALWAYS" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0" styleClass="activity-card">
                                            <children>
                                                <Label styleClass="placeholder-title" text="Recent Activity" />
                                                <Label fx:id="activityLine1" styleClass="activity-line" text="6 AVAILABLE items are ready for auction creation." wrapText="true" />
                                                <Label fx:id="activityLine2" styleClass="activity-line" text="4 RUNNING auctions need attention." wrapText="true" />
                                                <Label fx:id="activityLine3" styleClass="activity-line" text="11 SUSPENDED accounts are waiting for audit." wrapText="true" />
                                                <Label fx:id="activityLine4" styleClass="activity-line" text="3 FINISHED auctions need payment follow-up." wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>

                            <padding>
                                <Insets bottom="1.0" left="1.0" right="1.0" top="1.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </HBox>
    </children>
</AnchorPane>